{
  "manifest_version": 3,
  "name": "LinguaLens",
  "version": "1.3.0",
  "description": "AI-powered language learning on YouTube — dual subtitles, quizzes, word lookup, and more.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "optional_permissions": [
    "microphone"
  ],
  "background": {
    "service_worker": "background/worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": [
        "content/index.js"
      ],
      "css": [],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.elevenlabs.io/*",
    "https://*.auth0.com/*",
    "https://*.supabase.co/*"
  ]
}
